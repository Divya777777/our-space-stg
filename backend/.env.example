# Environment
NODE_ENV=development

# Server
PORT=3001
HOST=localhost

# Database URL
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://ourspace_app:your_password@localhost:3306/our_space_production"

# JWT Secrets (Generate using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_jwt_secret_here_64_characters_minimum
JWT_REFRESH_SECRET=your_refresh_secret_here_64_characters_minimum
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Session Secret
SESSION_SECRET=your_session_secret_here_64_characters_minimum

# Encryption Key (Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=your_encryption_key_here_32_bytes_64_hex_chars

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# CORS Origins (comma-separated for multiple)
CORS_ORIGIN=http://localhost:3000,http://localhost:5500

# File Upload
MAX_FILE_SIZE=2097152
UPLOAD_DIR=./uploads

# PeerJS Server
PEERJS_PORT=9000
PEERJS_PATH=/peerjs

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
